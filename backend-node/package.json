{
  "name": "backend-node",
  "version": "2.0.0",
  "description": "LexGuard AI — Node.js backend: 5-agent legal analysis pipeline powered by Google Gemini, NL API & Translate API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test:unit": "node --test src/tests/unit.test.js",
    "test:integration": "node --test src/tests/integration.test.js",
    "test": "node --test src/tests/unit.test.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": ["legal-ai", "gemini", "contract-analysis", "lexguard"],
  "author": "LexGuard AI",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@google/genai": "^2.3.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
