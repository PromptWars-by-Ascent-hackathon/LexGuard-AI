# ─────────────────────────────────────────────
# LexGuard AI — Backend Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ✅ Gemini AI API Key (get from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSyC3fIN4_lhIHSnj4sP4aFagypuhmJ1b8q0

# ✅ GCP Project
GCP_PROJECT_ID=promptwars-community-x-ascen
GCP_REGION=us-central1

# Google Cloud Storage — document uploads (24h auto-delete)
GCS_BUCKET_NAME=lexguard-uploads-promptwars

# Document AI — OCR processor
DOCUMENT_AI_PROCESSOR_ID=YOUR_PROCESSOR_ID_HERE
DOCUMENT_AI_LOCATION=us

# Firebase / Firestore
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# App Settings
APP_ENV=development
MAX_FILE_SIZE_MB=25
MAX_PAGES=150
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Pub/Sub topic for async pipeline
PUBSUB_TOPIC=lexguard-pipeline-jobs
